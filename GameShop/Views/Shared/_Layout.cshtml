<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" /> 
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <meta name="viewport" content="width=device-width" />
    <title>Game Shop</title>
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark fixed-top">
            <div class="container">

            <a class="navbar-brand me-4" asp-controller="Home" asp-action="Home"> GameShop
            </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center"> @if (User.Identity.IsAuthenticated)
                        {
                            // --- КОРИСТУВАЧ УВІЙШОВ ---

                            // 1. АДМІНКА
                            @if (User.IsInRole("admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Admin" asp-action="Admin">
                                        <i class="bi bi-gear-fill"></i> Admin
                                    </a>
                                </li>
                            }

                            // 2. МОЯ БІБЛІОТЕКА (НОВЕ)
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="UserLibrary" asp-action="UserLibrary">
                                    <i class="bi bi-collection-play"></i> Моя бібліотека
                                </a>
                            </li>

                            // 3. КОШИК (НОВЕ - ми його щойно робили)
                            <li class="nav-item">
                                <a class="nav-link text-success" asp-controller="Cart" asp-action="Cart">
                                    <i class="bi bi-cart4"></i> Кошик
                                </a>
                            </li>

                            // 4. ІМ'Я КОРИСТУВАЧА
                            <li class="nav-item ms-2">
                                <span class="nav-link text-warning">
                                     Привіт, @User.Identity.Name!
                                </span>
                            </li>

                            // 5. ВИХІД
                            <form asp-controller="UserAccount" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link text-secondary ms-2" style="text-decoration: none;">
                                    <i class="bi bi-box-arrow-right"></i> Вийти
                                </button>
                            </form>
                        }
                        else
                        {
                            // --- КОРИСТУВАЧ НЕ УВІЙШОВ ---


                            <li class="nav-item">
                                <a class="nav-link" asp-controller="UserAccount" asp-action="Login">
                                    Увійти
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-light ms-2" asp-controller="UserAccount" asp-action="Register">
                                    Реєстрація
                                </a>
                            </li>
                        }

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div style="padding-top: 56px;"></div>

    <div class="container-fluid p-0">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>