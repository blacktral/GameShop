@model IEnumerable<GameShop.Models.ViewModels.UserRolesViewModel>

@{
    ViewData["Title"] = "Список користувачів";
}

<h1>Керування ролями користувачів</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Ім'я (UserName)</th>
            <th>Email</th>
            <th>Ролі</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>@string.Join(", ", user.Roles)</td>

                <td>
                    <a asp-action="EditUserRole" asp-route-id="@user.UserId" class="btn btn-primary btn-sm">
                        Змінити роль
                    </a>

                    <form asp-action="DeleteUser" asp-route-id="@user.UserId" method="post" style="display:inline; margin-left: 5px;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('Ви ВПЕВНЕНІ, що хочете остаточно видалити користувача \'@user.Username\'? Цю дію неможливо скасувати.');">
                            Видалити
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>