@model GameShop.Models.Order

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Оформлення замовлення</h3>
                </div>
                <div class="card-body">

                    <form id="paymentForm" asp-action="Checkout" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <h5 class="card-title">Сума до сплати: <span class="text-success">@ViewBag.TotalAmount</span></h5> <hr />



                        <button type="submit" class="btn btn-success btn-lg w-100" id="payButton">
                            Підтвердити та сплатити
                        </button>
                    </form>

                    <div id="processingBlock" class="text-center d-none py-5">
                        <div class="spinner-border text-primary" style="width: 4rem; height: 4rem;" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <h4 class="mt-4" id="statusText">З'єднання з банком...</h4>
                        <p class="text-muted">Будь ласка, не закривайте сторінку.</p>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<script>
    document.getElementById('paymentForm').addEventListener('submit', function(e) {
        // 1. Зупиняємо миттєву відправку форми
        e.preventDefault();

        // 2. Ховаємо форму, показуємо анімацію
        document.getElementById('paymentForm').classList.add('d-none');
        document.getElementById('processingBlock').classList.remove('d-none');

        // 3. Змінюємо текст статусу з часом
        let statusText = document.getElementById('statusText');

        setTimeout(() => {
            statusText.innerText = "Перевірка реквізитів...";
            statusText.className = "mt-4 text-warning"; // Жовтий колір
        }, 1500); // через 1.5 сек

        setTimeout(() => {
            statusText.innerText = "Оплата підтверджена!";
            statusText.className = "mt-4 text-success"; // Зелений колір

            // 4. Реальна відправка форми на сервер
            e.target.submit();
        }, 3500); // через 3.5 сек
    });
</script>