@using GameShop.Models
@model IEnumerable<Game>

@{
    ViewData["Title"] = "";
}

<h1 class="mt-4 mb-5">@ViewData["Title"]</h1>

<div style="display: flex; flex-wrap: wrap; gap: 20px;">

    @foreach (var game in Model)
    {
        <a asp-controller="GameInfo"
           asp-action="GameInfo"
           asp-route-id="@game.GameId"
           class="game-card text-dark text-center"
           style="text-decoration: none; width: 220px; padding-bottom: 10px; border: 1px solid #ccc; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">

            <div style="margin-bottom: 10px;">
                <img src="@game.CoverImageUrl" alt="@game.Title"
                     style="width: 100%; height: 280px; object-fit: cover;">
            </div>

            <div class="game-title">
                <p style="color: #66c0f4; font-weight: bold; margin-bottom: 0;">@game.Title</p>
            </div>
        </a>
    }

</div>
